<Window x:Class="ScadaGUI.AddTagWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:ScadaGUI"
        mc:Ignorable="d"
        Title="Add Tag" Height="800" Width="700"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource MaterialDesignWindow}"
        Background="#0A0A0A"
        Foreground="{StaticResource YokogawaText}"
        TextElement.Foreground="{StaticResource YokogawaText}">

    <Grid Margin="20" Background="{DynamicResource YokogawaBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 0. Naslov -->
            <RowDefinition Height="Auto"/>
            <!-- 1. Radio Dugmad -->
            <RowDefinition Height="Auto"/>
            <!-- 2. Zajednička polja -->
            <RowDefinition Height="*"/>
            <!-- 3. Dinamička polja -->
            <RowDefinition Height="Auto"/>
            <!-- 4. Dugmad na dnu -->
        </Grid.RowDefinitions>

        <!-- 0. Naslov -->
        <TextBlock x:Name="LblTitle" Grid.Row="0" Text="Dodaj Novi Tag" FontSize="20" FontWeight="Bold" Foreground="{StaticResource YokogawaText}" Margin="0,0,0,15"/>

        <!-- 1. Radio dugmad -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock x:Name="LblTagType" Text="Tip taga: " VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,15,0"/>
            <RadioButton x:Name="RbAI" Content="AI (Analog Input)" GroupName="TagType" IsChecked="True" Checked="RadioButton_Checked" Margin="0,0,15,0"/>
            <RadioButton x:Name="RbAO" Content="AO (Analog Output)" GroupName="TagType" Checked="RadioButton_Checked" Margin="0,0,15,0"/>
            <RadioButton x:Name="RbDI" Content="DI (Digital Input)" GroupName="TagType" Checked="RadioButton_Checked" Margin="0,0,15,0"/>
            <RadioButton x:Name="RbDO" Content="DO (Digital Output)" GroupName="TagType" Checked="RadioButton_Checked"/>
            <RadioButton x:Name="RbAlarm" Content="Alarm" GroupName="TagType" Checked="RadioButton_Checked" Margin="15,0,0,0"/>
        </StackPanel>

        <!-- 2. Zajednička polja (samo za tagove, ne za alarm) -->
        <StackPanel x:Name="PanelCommon" Grid.Row="2" Margin="0,0,0,15">
            <TextBlock x:Name="LblName" Text="Ime Taga:" Foreground="{StaticResource YokogawaGreen}"/>
            <TextBox x:Name="TxtName" Margin="0,5,0,10" Height="30" Foreground="White" CaretBrush="White"/>

            <TextBlock x:Name="LblAddress" Text="I/O Adresa:" Foreground="{StaticResource YokogawaGrey}"/>
            <TextBox x:Name="TxtAddress" Margin="0,5,0,10" Height="30" Foreground="White" CaretBrush="White"/>

            <TextBlock x:Name="LblDescription" Text="Opis (Opciono):" Foreground="{StaticResource YokogawaGrey}"/>
            <TextBox x:Name="TxtDescription" Margin="0,5,0,10" Height="30" Foreground="White" CaretBrush="White"/>
        </StackPanel>

        <!-- 3. Dinamička polja -->
        <Grid Grid.Row="3">
            <!-- AI PANEL -->
            <StackPanel x:Name="PanelAI" Visibility="Visible">
                <TextBlock x:Name="LblAiLow" Text="Donja Granica (Min Vrednost):" Foreground="{StaticResource YokogawaRed}"/>
                <TextBox x:Name="TxtAiLowLimit" Margin="0,5,0,10" Height="30" Foreground="White"/>
                <TextBlock x:Name="LblAiHigh" Text="Gornja Granica (Max Vrednost):" Foreground="{StaticResource YokogawaGrey}"/>
                <TextBox x:Name="TxtAiHighLimit" Margin="0,5,0,10" Height="30" Foreground="White"/>
                <TextBlock x:Name="LblAiUnits" Text="Jedinica mere (Units):" Foreground="{StaticResource YokogawaGrey}"/>
                <TextBox x:Name="TxtAiUnits" Margin="0,5,0,10" Height="30" Foreground="White"/>
                <TextBlock x:Name="LblAiDeadband" Text="Deadband:" Foreground="{StaticResource YokogawaGrey}"/>
                <TextBox x:Name="TxtAiDeadband" Margin="0,5,0,10" Height="30" Foreground="White"/>
                <TextBlock x:Name="LblAiHysteresis" Text="Histereza (Hysteresis):" Foreground="{StaticResource YokogawaGrey}"/>
                <TextBox x:Name="TxtAiHysteresis" Margin="0,5,0,10" Height="30" Foreground="White"/>
                <TextBlock x:Name="LblAiScan" Text="Period Osvežavanja (s):" Foreground="{StaticResource YokogawaGrey}"/>
                <TextBox x:Name="TxtAiScanTime" Margin="0,5,0,10" Height="30" Foreground="White"/>
                <CheckBox x:Name="ChkAiOnScan" Content="Skeniranje uključeno (On Scan)" IsChecked="True" Foreground="{StaticResource YokogawaText}" Margin="0,5,0,10"/>
            </StackPanel>

            <!-- AO PANEL -->
            <StackPanel x:Name="PanelAO" Visibility="Collapsed">
                <TextBlock x:Name="LblAoInit" Text="Početna Vrednost:" Foreground="{StaticResource YokogawaGrey}"/>
                <TextBox x:Name="TxtAoInitValue" Margin="0,5,0,10" Height="30" Foreground="White"/>
            </StackPanel>

            <!-- DI PANEL -->
            <StackPanel x:Name="PanelDI" Visibility="Collapsed">
                <TextBlock x:Name="LblDiScan" Text="Period Skeniranja (s):" Foreground="{StaticResource YokogawaGrey}"/>
                <TextBox x:Name="TxtDiScanTime" Margin="0,5,0,10" Height="30" Foreground="White"/>
                <CheckBox x:Name="ChkDiOnScan" Content="Skeniranje uključeno (On Scan)" IsChecked="True" Foreground="{StaticResource YokogawaText}" Margin="0,5,0,10"/>
            </StackPanel>

            <!-- DO PANEL -->
            <StackPanel x:Name="PanelDO" Visibility="Collapsed">
                <TextBlock x:Name="LblDoInit" Text="Početna Vrednost (0 ili 1):" Foreground="{StaticResource YokogawaGrey}"/>
                <TextBox x:Name="TxtDoInitValue" Margin="0,5,0,10" Height="30" Foreground="White"/>
            </StackPanel>

            <!-- ALARM PANEL: alarm se vezuje za postojeći AI senzor -->
            <StackPanel x:Name="PanelAlarm" Visibility="Collapsed">
                <TextBlock x:Name="LblAlarmSensor" Text="Senzor (AI tag):" Foreground="{StaticResource YokogawaGreen}"/>
                <ComboBox x:Name="CbTagList" DisplayMemberPath="Name" SelectedValuePath="Name" Margin="0,5,0,10" Height="30"/>

                <TextBlock x:Name="LblAlarmLimit" Text="Granična vrednost:" Foreground="{StaticResource YokogawaGrey}"/>
                <TextBox x:Name="TxtAlarmLimit" Margin="0,5,0,10" Height="30" Foreground="White"/>

                <TextBlock x:Name="LblAlarmDirection" Text="Smer:" Foreground="{StaticResource YokogawaGrey}"/>
                <ComboBox x:Name="CbDirection" Margin="0,5,0,10" Height="30" SelectedIndex="0">
                    <ComboBoxItem Content="Above"/>
                    <ComboBoxItem Content="Below"/>
                </ComboBox>

                <TextBlock x:Name="LblAlarmMessage" Text="Poruka alarma:" Foreground="{StaticResource YokogawaGrey}"/>
                <TextBox x:Name="TxtAlarmMessage" Margin="0,5,0,10" Height="30" Foreground="White" CaretBrush="White"/>
            </StackPanel>
        </Grid>

        <!-- 4. Dugmad na dnu -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="BtnSave" Content="Sačuvaj" Click="SaveButton_Click"
                    Style="{StaticResource MaterialDesignFlatDarkBgButton}"
                    Background="{StaticResource YokogawaGreen}"
                    BorderBrush="{StaticResource YokogawaGreen}"
                    Foreground="Black" FontWeight="Bold" Width="100" Height="35" Margin="0,0,10,0" IsDefault="True"/>

            <Button x:Name="BtnCancel" Content="Otkaži" IsCancel="True"
                    Style="{StaticResource MaterialDesignFlatDarkBgButton}"
                    Background="{StaticResource YokogawaGrey}"
                    BorderBrush="{StaticResource YokogawaGrey}"
                    Foreground="White" Width="100" Height="35"/>
        </StackPanel>
    </Grid>
</Window>
