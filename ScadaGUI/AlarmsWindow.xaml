<Window x:Class="ScadaGUI.AlarmsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Alarmi" Height="420" Width="720"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="LblTitle" Grid.Row="0" Text="Definisani alarmi" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

        <DataGrid x:Name="AlarmsGrid" Grid.Row="1"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn x:Name="ColMessage" Header="Poruka" Binding="{Binding Message}" Width="2*"/>
                <DataGridTextColumn x:Name="ColTag" Header="Tag" Binding="{Binding TagName}" Width="*"/>
                <DataGridTextColumn x:Name="ColLimit" Header="Granica" Binding="{Binding LimitValue}" Width="Auto"/>
                <DataGridTextColumn x:Name="ColDirection" Header="Smjer" Binding="{Binding Direction}" Width="Auto"/>
                <DataGridTextColumn x:Name="ColState" Header="Stanje" Binding="{Binding State}" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="BtnActivate" Content="Aktiviraj (simulacija)" Click="ActivateButton_Click"
                    Background="{StaticResource YokogawaRed}" BorderBrush="{StaticResource YokogawaRed}"
                    Foreground="White" FontWeight="Bold" Width="170" Height="34" Margin="0,0,10,0"/>
            <Button x:Name="BtnAcknowledge" Content="Acknowledge" Click="AcknowledgeButton_Click"
                    Background="{StaticResource YokogawaGreen}" BorderBrush="{StaticResource YokogawaGreen}"
                    Foreground="Black" FontWeight="Bold" Width="130" Height="34" Margin="0,0,10,0"/>
            <Button x:Name="BtnClose" Content="Zatvori" IsCancel="True" Width="100" Height="34"
                    Background="{StaticResource YokogawaGrey}" BorderBrush="{StaticResource YokogawaGrey}"
                    Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
