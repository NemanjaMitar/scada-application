<Window x:Class="ScadaGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ScadaGUI"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="SCADA Application" Height="650" Width="1200"
        Background="Black"
        Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="DefaultCellStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="BtnAddTag" Content="DODAJ" Click="AddButton_Click" Width="100" Height="35" Margin="0,0,10,0" Background="LimeGreen" Foreground="Black" FontWeight="Bold"/>
            <Button x:Name="BtnRemoveTag" Content="OBRISI" Click="RemoveButton_Click" Width="100" Height="35" Margin="0,0,10,0" Background="Red" Foreground="White" FontWeight="Bold"/>
            <Button x:Name="BtnDetails" Content="DETALJI" Click="DetailsButton_Click" Width="100" Height="35" Margin="0,0,10,0" Background="Orange" Foreground="Black" FontWeight="Bold"/>
            <Button x:Name="BtnToggleScan" Content="ON/OFF SCAN" Click="ToggleScanButton_Click" Width="110" Height="35" Margin="0,0,10,0" Background="CornflowerBlue" Foreground="White" FontWeight="Bold"/>
            <Button x:Name="BtnReport" Content="REPORT" Click="ReportButton_Click" Width="100" Height="35" Margin="0,0,10,0" Background="Gold" Foreground="Black" FontWeight="Bold"/>
            <Button x:Name="BtnToggleTheme" Content="Tema" Click="BtnToggleTheme_Click" Width="80" Height="35" Margin="0,0,10,0" Background="Gray" Foreground="White"/>
            <TextBlock x:Name="TbCurrentUser" VerticalAlignment="Center" Margin="20,0,0,0" Foreground="White" FontWeight="Bold"/>
        </StackPanel>

        <!-- Tags DataGrid -->
        <DataGrid Grid.Row="1" x:Name="TagsDataGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" SelectionUnit="FullRow" GridLinesVisibility="All"
                  Background="#111111" RowBackground="#1A1A1A" AlternatingRowBackground="#222222"
                  Foreground="White" BorderBrush="Gray" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Ime" Binding="{Binding Name}" Width="120" ElementStyle="{StaticResource DefaultCellStyle}"/>
                <DataGridTextColumn Header="Tip" Binding="{Binding Type}" Width="60" ElementStyle="{StaticResource DefaultCellStyle}"/>
                <DataGridTextColumn Header="Adresa" Binding="{Binding Address}" Width="100" ElementStyle="{StaticResource DefaultCellStyle}"/>
                <DataGridTextColumn Header="Opis" Binding="{Binding Description}" Width="150" ElementStyle="{StaticResource DefaultCellStyle}"/>
                <DataGridTextColumn Header="Vrednost" Binding="{Binding Value, StringFormat={}{0:F2}}" Width="100" ElementStyle="{StaticResource DefaultCellStyle}"/>
                <DataGridTextColumn Header="Trenutna" Binding="{Binding CurrentValue}" Width="100" ElementStyle="{StaticResource DefaultCellStyle}"/>
                <DataGridTextColumn Header="On Scan" Binding="{Binding IsOnScan}" Width="70" ElementStyle="{StaticResource DefaultCellStyle}"/>
                <DataGridTextColumn Header="Scan Time" Binding="{Binding ScanTime}" Width="90" ElementStyle="{StaticResource DefaultCellStyle}"/>
                <DataGridTextColumn Header="Units" Binding="{Binding Units}" Width="60" ElementStyle="{StaticResource DefaultCellStyle}"/>
                <DataGridTextColumn Header="Low Limit" Binding="{Binding LowLimit, StringFormat={}{0:F2}}" Width="80" ElementStyle="{StaticResource DefaultCellStyle}"/>
                <DataGridTextColumn Header="High Limit" Binding="{Binding HighLimit, StringFormat={}{0:F2}}" Width="80" ElementStyle="{StaticResource DefaultCellStyle}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Bottom panel: Write value + Alarms -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="0,0,10,0" Padding="10" Background="#1A1A1A">
                <StackPanel>
                    <TextBlock Text="UPIS VREDNOSTI" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" Foreground="White"/>
                    <TextBlock Text="Nova vrednost:" Foreground="White"/>
                    <TextBox x:Name="TxtWriteValue" Margin="0,5,0,10" Foreground="White" Background="#333333"/>
                    <Button x:Name="BtnWrite" Content="UPISI" Click="WriteValueButton_Click" Width="100" Height="30" HorizontalAlignment="Left" Background="LimeGreen" Foreground="Black" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Padding="10" Background="#1A1A1A">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="AKTIVNI ALARMI" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" Foreground="Red"/>
                    <DataGrid Grid.Row="1" x:Name="AlarmsDataGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" Background="#111111" RowBackground="#1A1A1A"
                              Foreground="White" BorderBrush="Gray">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" ElementStyle="{StaticResource DefaultCellStyle}"/>
                            <DataGridTextColumn Header="Tag" Binding="{Binding TagName}" Width="100" ElementStyle="{StaticResource DefaultCellStyle}"/>
                            <DataGridTextColumn Header="Poruka" Binding="{Binding Message}" Width="*" ElementStyle="{StaticResource DefaultCellStyle}"/>
                            <DataGridTextColumn Header="Vreme" Binding="{Binding Timestamp, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="130" ElementStyle="{StaticResource DefaultCellStyle}"/>
                            <DataGridCheckBoxColumn Header="Ack" Binding="{Binding IsAcknowledged}" Width="50"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
